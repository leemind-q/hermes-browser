+  const h = r.height;
+  if (h < 120) {
+    empty.setAttribute('data-size', 'sm');
+  } else if (h < 220) {
+    empty.setAttribute('data-size', 'md');
+  } else {
+    empty.setAttribute('data-size', 'lg');
+  }
